{
  "name": "helix-app",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:property": "jest --testPathPattern=property.test",
    "electron-dev": "electron .",
    "build:exe": "next build && electron-builder"
  },
  "build": {
    "appId": "com.helix.app",
    "win": {
      "target": "nsis",
      "icon": "build/image.ico"
    },
    "nsis": {
      "oneClick": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "HELIX",
      "license": "build/license.txt",
      "installerIcon": "build/image.ico",
      "uninstallerIcon": "build/image.ico",
      "installerHeader": "public/logo.png",
      "runAfterFinish": true
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ]
  },
  "dependencies": {
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "@tailwindcss/postcss": "^4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint-config-next": "16.2.4",
    "socket.io-client": "^4.5.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@types/jest": "^30.0.0",
    "eslint": "^9",
    "fast-check": "^4.7.0",
    "jest": "^30.3.0",
    "jsdom": "^29.0.2",
    "ts-jest": "^29.4.9",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  }
}
